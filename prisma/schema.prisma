generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model User {
  id                    String                  @id @default(uuid())
  username              String                  @unique
  name                  String
  full_name             String?
  email                 String                  @unique
  facebook_profile_url  String?
  password              String
  role                  UserRole                @default(USER)
  plan                  UserPlan                @default(FREE)
  plan_expires_at       DateTime?
  chiikawa_promo_claimed_at DateTime?
  department            String
  avatar_url            String?
  facebook_verified     Boolean                 @default(false)
  is_active             Boolean                 @default(true)
  daily_token_limit     Int                     @default(100000)
  last_token_reset      DateTime                @default(now())
  tokens_used_today     Int                     @default(0)
  username_changed      Boolean                 @default(false)
  trust_score           Int                     @default(80)
  is_verified           Boolean                 @default(false)
  quick_note            String?
  total_auto_approved   Int                     @default(0)
  total_rejected        Int                     @default(0)
  hope_stars            Int                     @default(0)
  used_stars_this_month Int                     @default(0)
  last_star_reset_at    DateTime?
  theme                 String?                 @default("system")
  pc_score              Int                     @default(0)
  wallet_balance        Int                     @default(0)
  reviewed_checkins     Checkin[]               @relation("AdminReviewedCheckins")
  checkins              Checkin[]               @relation("UserCheckins")
  pc_submissions        PcSubmission[]          @relation("UserPcSubmissions")
  reviewed_pc_submissions PcSubmission[]        @relation("AdminReviewedPcSubmissions")
  tags                  Tag[]
  task_assignments      TaskAssignee[]
  created_tasks         Task[]                  @relation("UserCreatedTasks")
  timetable_rows        TimetableRow[]
  timetable_config      UserTimetableConfig?
  workspaces            Workspace[]             @relation("UserWorkspaces")
  collaborators         WorkspaceCollaborator[]

  notifications Notification[]
  trust_score_logs TrustScoreLog[]

  @@index([email])
}

/// Lịch sử thay đổi Trust Score của người dùng
model TrustScoreLog {
  id         String   @id @default(uuid())
  user_id    String
  change     Int
  score_after Int
  action     String
  description String?
  post_id    String?
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([created_at])
}

/// Bài tập Build PC hàng ngày do AI sinh ra (Phân hệ Đào tạo Build PC)
model PcBuildTask {
  id            String    @id @default(uuid())
  date          DateTime  @default(now())
  customer_need String
  max_budget    Float
  requirements  String
  difficulty    String    @default("medium")
  deadline      DateTime?
  is_archived   Boolean   @default(false)
  created_at    DateTime  @default(now())
  submissions   Checkin[]

  @@index([date])
}

model Post {
  id                String    @id @default(uuid())
  title             String
  url               String
  thumbnail_url     String?
  description       String
  start_at          DateTime
  team              Team      @default(ALL)
  is_archived       Boolean   @default(false)
  created_at        DateTime  @default(now())
  allow_late_submit Boolean   @default(false)
  author            String?
  checkins          Checkin[]
}

model Checkin {
  id                    String        @id @default(uuid())
  user_id               String
  post_id               String?
  image_url             String
  exif_time             DateTime?
  submitted_at          DateTime      @default(now())
  reviewed_at           DateTime?
  status                CheckinStatus @default(PENDING)
  reject_reason         String?
  is_ai_flagged         Boolean       @default(false)
  ai_confidence         Float?
  reviewed_by           String?
  ai_analysis_reason    String?
  ai_extracted_title    String?
  ai_extracted_username String?
  image_phash           String?
  ai_is_facebook_ui     Boolean?
  ai_is_public_mode     Boolean?
  task_type             String        @default("SHARE_POST")
  build_data            Json?
  pc_task_id            String?
  post                  Post?         @relation(fields: [post_id], references: [id], onDelete: Cascade)
  reviewer              User?         @relation("AdminReviewedCheckins", fields: [reviewed_by], references: [id])
  user                  User          @relation("UserCheckins", fields: [user_id], references: [id], onDelete: Cascade)
  pc_task               PcBuildTask?  @relation(fields: [pc_task_id], references: [id])

  @@index([user_id])
  @@index([post_id])
  @@index([status])
  @@index([task_type])
  @@index([pc_task_id])
}

/// Bài tập Build PC do AI sinh từ Kho linh kiện — mỗi ngày nhiều bài
model PcExercise {
  id            String         @id @default(uuid())
  exercise_date DateTime
  title         String
  description   String
  requirements  Json
  difficulty    String         @default("medium")
  order_index   Int            @default(0)
  team          Team           @default(ALL)
  created_at    DateTime       @default(now())
  submissions   PcSubmission[]

  @@unique([exercise_date, order_index])
  @@index([exercise_date])
}

/// Bài nộp Build PC — tối đa 5 bài/ngày/user, duyệt qua admin queue
model PcSubmission {
  id            String        @id @default(uuid())
  user_id       String
  exercise_id   String
  parts_answer  Json
  explanation   String
  image_urls    Json          @default("[]")
  submitted_at  DateTime      @default(now())
  reviewed_at   DateTime?
  status        CheckinStatus @default(PENDING)
  reject_reason String?
  reviewed_by   String?
  ai_feedback   String?
  ai_score      Float?
  exercise      PcExercise    @relation(fields: [exercise_id], references: [id], onDelete: Cascade)
  user          User          @relation("UserPcSubmissions", fields: [user_id], references: [id], onDelete: Cascade)
  reviewer      User?         @relation("AdminReviewedPcSubmissions", fields: [reviewed_by], references: [id])

  @@index([user_id, submitted_at])
  @@index([status])
  @@index([exercise_id])
}

/// Thông báo trong ứng dụng — gửi tới user khi có kết quả duyệt bài, v.v.
model Notification {
  id              String   @id @default(uuid())
  user_id         String
  type            String   /// PC_BUILD_APPROVED | PC_BUILD_REJECTED | ...
  title           String
  message         String
  reference_id    String?  /// ID của submission/checkin liên quan
  reference_type  String?  /// "pc_submission" | "checkin" | ...
  is_read         Boolean  @default(false)
  created_at      DateTime @default(now())
  read_at         DateTime?
  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, is_read])
  @@index([user_id, created_at])
}

model SystemSetting {
  id    String @id @default(uuid())
  key   String @unique
  value String
}

model Department {
  id   String @id @default(uuid())
  name String @unique
}

/// Đơn hàng thanh toán qua PayOS
model Order {
  id        String    @id @default(cuid())
  userId    String
  planId    String                         // "pro" | "max"
  amount    Int                            // VNĐ
  status    String    @default("pending")  // pending | paid | expired | failed
  orderCode Int       @unique              // Mã đơn hàng gửi cho PayOS
  createdAt DateTime  @default(now())
  paidAt    DateTime?

  @@index([userId])
  @@index([status])
  @@index([orderCode])
}

/// Trạng thái đăng ký gói của từng user
model Subscription {
  id        String    @id @default(cuid())
  userId    String    @unique
  plan      String    @default("free")     // free | pro | max
  expiresAt DateTime?
  updatedAt DateTime  @updatedAt

  @@index([userId])
}

model Workspace {
  id               String                     @id @default(uuid())
  name             String
  description      String?
  icon             String?
  color            String?
  owner_id         String
  createdAt        DateTime                   @default(now())
  is_default       Boolean                    @default(false)
  is_public        Boolean                    @default(true)
  type             String                     @default("CUSTOM")
  customProperties CustomPropertyDefinition[]
  tags             Tag[]                      @relation("WorkspaceTags")
  tasks            Task[]                     @relation("WorkspaceTasks")
  owner            User                       @relation("UserWorkspaces", fields: [owner_id], references: [id], onDelete: Cascade)
  collaborators    WorkspaceCollaborator[]
}

model Tag {
  id           String    @id @default(uuid())
  name         String
  color        String?
  workspace_id String
  user_id      String
  user         User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  workspace    Workspace @relation("WorkspaceTags", fields: [workspace_id], references: [id], onDelete: Cascade)
  tasks        Task[]    @relation("TaskTags")

  @@unique([name, workspace_id, user_id])
}

model WorkspaceCollaborator {
  id           String    @id @default(uuid())
  workspace_id String
  user_id      String
  role         String    @default("MEMBER")
  invited_at   DateTime  @default(now())
  user         User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@unique([workspace_id, user_id])
}

model Task {
  id               String                @id @default(uuid())
  title            String
  description      String?
  status           TaskStatus            @default(TODO)
  due_date         DateTime?
  workspace_id     String
  creator_id       String
  is_archived      Boolean               @default(false)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  customProperties CustomPropertyValue[]
  creator          User                  @relation("UserCreatedTasks", fields: [creator_id], references: [id], onDelete: Cascade)
  workspace        Workspace             @relation("WorkspaceTasks", fields: [workspace_id], references: [id], onDelete: Cascade)
  note             TaskNote?
  tags             Tag[]                 @relation("TaskTags")
  assignees        TaskAssignee[]
}

model TaskAssignee {
  task_id String
  user_id String
  task   Task @relation(fields: [task_id], references: [id], onDelete: Cascade)
  user   User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([task_id, user_id])
}

model TaskNote {
  id                  String         @id @default(uuid())
  task_id             String         @unique
  content             Json?
  revision            Int            @default(0)
  last_edited_by_id   String?
  last_edited_by_name String?
  updatedAt           DateTime       @updatedAt
  embedding           NoteEmbedding?
  task                Task           @relation(fields: [task_id], references: [id], onDelete: Cascade)
}

model TaskNoteBlockLock {
  task_id    String
  block_id   String
  user_id    String
  user_name  String?
  expires_at DateTime

  @@id([task_id, block_id])
  @@index([task_id])
  @@index([expires_at])
}

model TaskNotePresence {
  task_id    String
  user_id    String
  user_name  String?
  expires_at DateTime

  @@id([task_id, user_id])
  @@index([task_id])
  @@index([expires_at])
}

model NoteEmbedding {
  id        String                 @id @default(uuid())
  note_id   String                 @unique
  embedding Unsupported("vector")?
  note      TaskNote               @relation(fields: [note_id], references: [id], onDelete: Cascade)
}

model SystemStatus {
  id             String   @id @default(uuid())
  is_maintenance Boolean  @default(false)
  updatedAt      DateTime @updatedAt
}

model CustomPropertyDefinition {
  id           String                @id @default(uuid())
  workspace_id String
  name         String
  type         CustomPropertyType
  options      Json?
  created_at   DateTime              @default(now())
  workspace    Workspace             @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  values       CustomPropertyValue[]

  @@unique([workspace_id, name])
}

model CustomPropertyValue {
  id            String                   @id @default(uuid())
  task_id       String
  definition_id String
  value_text    String?
  value_number  Float?
  value_boolean Boolean?
  value_date    DateTime?
  definition    CustomPropertyDefinition @relation(fields: [definition_id], references: [id], onDelete: Cascade)
  task          Task                     @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@unique([task_id, definition_id])
}

model UserTimetableConfig {
  id                 String   @id @default(uuid())
  user_id            String   @unique
  max_focus_time     Int      @default(120)
  is_job_flexible    Boolean  @default(false)
  best_energy_time   String   @default("morning")
  best_learning_time String   @default("morning")
  max_learning_time  Int      @default(60)
  sync_task_manager  Boolean  @default(false)
  visible_columns    Json?
  is_onboarded       Boolean  @default(false)
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt
  user               User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model TimetableRow {
  id         String          @id @default(uuid())
  user_id    String
  title      String
  row_type   String          @default("custom")
  start_time String
  end_time   String
  order      Int
  is_fixed   Boolean         @default(false)
  is_locked  Boolean         @default(false)
  created_at DateTime        @default(now())
  updated_at DateTime        @updatedAt
  cells      TimetableCell[]
  user       User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model TimetableCell {
  id          String       @id @default(uuid())
  row_id      String
  column_name String
  content     Json?
  task_ids    Json?
  is_deadline Boolean      @default(false)
  row         TimetableRow @relation(fields: [row_id], references: [id], onDelete: Cascade)

  @@unique([row_id, column_name])
}

enum UserRole {
  ADMIN
  USER
}

enum UserPlan {
  FREE
  PRO
  MAX
}

/// Chỉ 2 phòng ban cốt lõi: TECH (Kỹ thuật) và SALES (Kinh doanh)
enum Team {
  ALL
  TECH
  SALES
  MARKETING
}

enum CheckinStatus {
  AUTO_APPROVED
  PENDING
  APPROVED
  REJECTED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum CustomPropertyType {
  TEXT
  NUMBER
  SELECT
  MULTI_SELECT
  DATE
  CHECKBOX
  URL
  EMAIL
  PHONE
}
