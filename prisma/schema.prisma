generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// ENUMS
// ──────────────────────────────────────────────

enum UserRole {
  ADMIN
  USER
}

/// Chỉ 2 phòng ban cốt lõi: TECH (Kỹ thuật) và SALES (Kinh doanh)
enum Team {
  TECH
  SALES
}

enum CheckinStatus {
  AUTO_APPROVED
  PENDING
  APPROVED
  REJECTED
}

// ──────────────────────────────────────────────
// MODELS
// ──────────────────────────────────────────────

model User {
  id                  String    @id @default(uuid())
  username            String    @unique
  name                String
  email               String    @unique
  password            String
  phone               String?
  role                UserRole  @default(USER)
  department          Team      @default(TECH)
  facebook_link       String?
  avatar_url          String?
  hope_stars          Int       @default(0)
  used_stars_this_month Int     @default(0)
  last_star_reset_at  DateTime?  @default(now())
  is_onboarded        Boolean   @default(false)
  is_active           Boolean   @default(true)
  weekly_checkin_count Int      @default(0)

  // Relations
  checkins          Checkin[] @relation("UserCheckins")
  reviewed_checkins Checkin[] @relation("AdminReviewedCheckins")

  // Serverless-friendly indexes
  @@index([username])
  @@index([email])
  @@index([department])
}

model Post {
  id            String    @id @default(uuid())
  title         String
  url           String
  thumbnail_url String?
  description   String
  start_at      DateTime
  team          String    @default("TECH")  // "TECH" | "SALES"
  is_archived   Boolean   @default(false)
  created_at    DateTime  @default(now())

  // Relations
  checkins Checkin[]

  @@index([team])
  @@index([is_archived])
  @@index([start_at])
}

model Checkin {
  id            String        @id @default(uuid())
  user_id       String
  post_id       String
  image_url     String
  exif_time     DateTime?
  submitted_at  DateTime      @default(now())
  status        CheckinStatus @default(PENDING)
  reject_reason String?
  is_ai_flagged Boolean       @default(false)
  ai_confidence Float?
  reviewed_by   String?

  // Relations
  post     Post  @relation(fields: [post_id], references: [id], onDelete: Cascade)
  reviewer User? @relation("AdminReviewedCheckins", fields: [reviewed_by], references: [id])
  user     User  @relation("UserCheckins", fields: [user_id], references: [id], onDelete: Cascade)

  // Serverless-friendly indexes
  @@index([user_id])
  @@index([post_id])
  @@index([status])
  @@index([reviewed_by])
  @@index([submitted_at])
}

model SystemSetting {
  id    String @id @default(uuid())
  key   String @unique
  value String
}
