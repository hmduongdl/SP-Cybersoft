generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model User {
  id                   String    @id @default(uuid())
  username             String    @unique
  username_changed     Boolean   @default(false)
  is_verified          Boolean   @default(false)
  name                 String
  full_name            String?
  email                String    @unique
  facebook_profile_url String?
  password             String
  role                 UserRole  @default(USER)
  department           String
  avatar_url           String?
  facebook_verified    Boolean   @default(false)
  is_active            Boolean   @default(true)
  daily_token_limit    Int       @default(100000)
  last_token_reset     DateTime  @default(now())
  tokens_used_today    Int       @default(0)
  hope_stars           Int       @default(0)
  used_stars_this_month Int      @default(0)
  last_star_reset_at   DateTime  @default(now())
  trust_score          Int       @default(50)
  reviewed_checkins    Checkin[] @relation("AdminReviewedCheckins")
  checkins             Checkin[] @relation("UserCheckins")
  workspaces           Workspace[] @relation("UserWorkspaces")
  created_tasks        Task[]      @relation("UserCreatedTasks")

  @@index([email])
}

model Post {
  id            String    @id @default(uuid())
  title         String
  url           String
  thumbnail_url String?
  description   String
  author        String?
  start_at      DateTime
  team          Team      @default(ALL)
  is_archived   Boolean   @default(false)
  allow_late_submit Boolean @default(false)
  created_at    DateTime  @default(now())
  checkins      Checkin[]
}

model Checkin {
  id            String        @id @default(uuid())
  user_id       String
  post_id       String
  image_url     String
  exif_time     DateTime?
  submitted_at  DateTime      @default(now())
  status        CheckinStatus @default(PENDING)
  reject_reason String?
  is_ai_flagged Boolean       @default(false)
  ai_confidence Float?
  ai_extracted_username String?
  ai_extracted_title   String?
  ai_analysis_reason   String?
  reviewed_by   String?
  post          Post          @relation(fields: [post_id], references: [id], onDelete: Cascade)
  reviewer      User?         @relation("AdminReviewedCheckins", fields: [reviewed_by], references: [id])
  user          User          @relation("UserCheckins", fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([post_id])
  @@index([status])
}

model SystemSetting {
  id    String @id @default(uuid())
  key   String @unique
  value String
}

model Department {
  id   String @id @default(uuid())
  name String @unique
}

enum UserRole {
  ADMIN
  USER
}

/// Chỉ 2 phòng ban cốt lõi: TECH (Kỹ thuật) và SALES (Kinh doanh)
enum Team {
  ALL
  TECH
  SALES
  MARKETING
}

enum CheckinStatus {
  AUTO_APPROVED
  PENDING
  APPROVED
  REJECTED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model Workspace {
  id          String   @id @default(uuid())
  name        String
  description String?
  icon        String?
  color       String?
  owner_id    String
  createdAt   DateTime @default(now())

  owner       User     @relation("UserWorkspaces", fields: [owner_id], references: [id], onDelete: Cascade)
  tags        Tag[]    @relation("WorkspaceTags")
  tasks       Task[]   @relation("WorkspaceTasks")
}

model Tag {
  id           String    @id @default(uuid())
  name         String
  color        String?
  workspace_id String

  workspace    Workspace @relation("WorkspaceTags", fields: [workspace_id], references: [id], onDelete: Cascade)
  tasks        Task[]    @relation("TaskTags")

  @@unique([name, workspace_id])
}

model Task {
  id           String     @id @default(uuid())
  title        String
  description  String?
  status       TaskStatus @default(TODO)
  due_date     DateTime?
  workspace_id String
  creator_id   String
  is_archived  Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  workspace    Workspace  @relation("WorkspaceTasks", fields: [workspace_id], references: [id], onDelete: Cascade)
  creator      User       @relation("UserCreatedTasks", fields: [creator_id], references: [id], onDelete: Cascade)
  tags         Tag[]      @relation("TaskTags")
  note         TaskNote?
}

model TaskNote {
  id        String   @id @default(uuid())
  task_id   String   @unique
  content   Json?
  updatedAt DateTime @updatedAt

  task      Task     @relation(fields: [task_id], references: [id], onDelete: Cascade)
  embedding NoteEmbedding?
}

model NoteEmbedding {
  id        String   @id @default(uuid())
  note_id   String   @unique
  embedding Unsupported("vector(768)")?

  note      TaskNote @relation(fields: [note_id], references: [id], onDelete: Cascade)
}

model SystemStatus {
  id             String   @id @default(uuid())
  is_maintenance Boolean  @default(false)
  updatedAt      DateTime @updatedAt
}
