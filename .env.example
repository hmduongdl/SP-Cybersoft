# Database connection (e.g. Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host:port/dbname?schema=public"

# NextAuth configuration
NEXTAUTH_SECRET="your-random-secret-at-least-32-chars"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Resend email API
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxx"
RESEND_EMAIL_DOMAIN="your-domain.com"
RESEND_FROM_EMAIL="noreply@your-domain.com"
RESEND_FROM_NAME="Your App"
TEST_WELCOME_EMAIL="user@example.com"
TEST_WELCOME_NAME="John Doe"

# Admin credentials
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"

# Facebook OAuth (Server-side)
AUTH_FACEBOOK_ID="your-facebook-app-id"
AUTH_FACEBOOK_SECRET="your-facebook-app-secret"

# Facebook Client-side SDK (must start with NEXT_PUBLIC_)
NEXT_PUBLIC_FACEBOOK_APP_ID="your-facebook-app-id"

# Vercel Blob Storage (required for check-in image uploads)
# Get token from: https://vercel.com/dashboard/stores > Blob > .env
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxx"

# Uploadthing Legacy Config (legacy image upload)
UPLOADTHING_SECRET="sk_live_xxxxxxxx"
UPLOADTHING_APP_ID="xxxxxxxxxx"

# OpenAI-compatible API keys
OPENAI_API_KEY="your-openai-api-key"
OPENAI_BASE_URL="https://v98store.com/v1"
AIBOX_DEFAULT_API_KEY="your-default-api-key"
AIBOX_CODEX_API_KEY="your-codex-api-key"
AIBOX_API_KEY="your-api-key"
AIBOX_BASE_URL="https://api.your-ai-provider.com/v1"

# Build PC AI worker tuning
PC_BUILD_VISION_TIMEOUT_MS="90000"
PC_BUILD_VISION_RETRIES="1"
PC_BUILD_AI_RETRIES="1"
PC_BUILD_MAX_AI_TOKENS="4500"

# Cron cleanup for expired PC build submissions (Authorization: Bearer <CRON_SECRET>)
CRON_SECRET="change-me-to-a-random-cleanup-secret"

# Model definitions
MODEL_DEEPSEEK_PRO="deepseek-v4-pro[1m]"
MODEL_DEEPSEEK_FLASH="deepseek-v4-flash[1m]"
MODEL_GEMINI_VISION="gemini-2.5-flash"
